"""
pages/01_Dashboard.py

Dashboard-Seite der CatchYourFlight-App.
Zeigt drei interaktive Diagramme mit historischen Flugverspätungsstatistiken
für die 5 grössten US-Flughäfen (2015):
  1. Verspätungen nach Tageszeit (Liniendiagramm)
  2. Verspätungen nach Wochentag (Balkendiagramm)
  3. Verspätungen nach Airline (horizontales Balkendiagramm)

Autoren: Sára Jankovičová
Datum:   13 hours ago (Commit 97774e9)

Quellen:
- Claude (claude.ai): Plotly-Diagramme (go.Figure, go.Scatter, go.Bar),
  st.set_page_config, st.plotly_chart, unsafe_allow_html sowie die
  gesamte Layout-Konfiguration (update_layout) wurden mit Claude erarbeitet,
  da Plotly und Streamlit-spezifische Konfigurationen nicht im Unterricht
  behandelt wurden.
"""

# Importiert Streamlit für die Web-App-Oberfläche
# Hilfsmittel: Claude – Streamlit wurde im Unterricht nicht behandelt
import streamlit as st

# Importiert plotly.graph_objects für interaktive Diagramme
# Hilfsmittel: Claude – Plotly wurde im Unterricht nicht behandelt
import plotly.graph_objects as go

# Importiert die Navbar-Funktion aus dem utils-Ordner (zeigt die Navigationsleiste an)
from utils.navbar import show_navbar

# Importiert die drei Daten-Funktionen aus utils/dashboard_data.py,
# welche die aggregierten Verspätungsstatistiken als DataFrames zurückgeben
from utils.dashboard_data import (
    get_delay_by_hour,      # Verspätungsrate nach Abflugstunde
    get_delay_by_weekday,   # Verspätungsrate nach Wochentag
    get_delay_by_airline,   # Verspätungsrate nach Airline
)

# ── Seitenkonfiguration ───────────────────────────────────────────────────────
# Konfiguriert die Streamlit-Seite: Tab-Titel, Icon, Layout und Sidebar-Zustand
# Hilfsmittel: Claude – st.set_page_config ist Streamlit-spezifisch und wurde im Unterricht nicht behandelt
st.set_page_config(
    page_title="Dashboard – CatchYourFlight",   # Titel im Browser-Tab (String)
    page_icon="✈",                              # Emoji-Icon im Browser-Tab (String)
    layout="wide",                              # Breites Layout: App nutzt die volle Fensterbreite
    initial_sidebar_state="collapsed",          # Sidebar beim Start eingeklappt
)

# Versteckt die Streamlit-Sidebar und den Einklapp-Button per CSS
# unsafe_allow_html=True erlaubt das Einfügen von rohem HTML/CSS
# Hilfsmittel: Claude – CSS-Injektion via st.markdown wurde im Unterricht nicht behandelt
st.markdown("<style>[data-testid='stSidebar'],[data-testid='collapsedControl']{display:none!important}</style>", unsafe_allow_html=True)

# ── Navbar anzeigen ───────────────────────────────────────────────────────────
# Ruft die show_navbar()-Funktion auf, die die Navigationsleiste rendert
show_navbar()

# ── Titel ─────────────────────────────────────────────────────────────────────
# Zeigt den Seitentitel als grosse Überschrift an
st.title("Dashboard")
# Zeigt einen erklärenden Untertitel als Markdown-Text an
st.markdown("Delay statistics for the 5 busiest US airports (ATL · ORD · JFK · LAX · DEN) — 2015 data.")
# Zeigt eine horizontale Trennlinie an
st.markdown("---")

# ── Daten laden ───────────────────────────────────────────────────────────────
# Ruft die drei Daten-Funktionen auf und speichert die DataFrames in Variablen
df_hour    = get_delay_by_hour()      # DataFrame: Stunde → Verspätungsrate
df_weekday = get_delay_by_weekday()   # DataFrame: Wochentag → Verspätungsrate
df_airline = get_delay_by_airline()   # DataFrame: Airline → Verspätungsrate

# Farbvariablen als Strings (Hex-Farbcodes) für alle drei Charts
COLOR_LINE = "#3B82F6"   # Blau für Linien
COLOR_BAR  = "#6366F1"   # Lila für Balken
COLOR_GRID = "#f0f0f0"   # Hellgrau für Gitternetz

# ── CHART 1: VERSPÄTUNGEN NACH TAGESZEIT (Liniendiagramm) ─────────────────────
# Zeigt eine Unterüberschrift für Chart 1
st.subheader("Delays by Time of Day")
# Zeigt einen erklärenden Hinweistext (kleiner grauer Text) unter der Überschrift
st.caption("On average delays accumulate over the course of the day.")

# List Comprehension: erstellt eine Liste von Stunden-Strings (z.B. "06:00")
# aus der "hour"-Spalte des DataFrames (Unterrichtsinhalt: List Comprehension, f-String)
hour_labels = [f"{h:02d}:00" for h in df_hour["hour"]]

# Erstellt ein leeres Plotly-Figur-Objekt für Chart 1
# Hilfsmittel: Claude – go.Figure und go.Scatter sind Plotly-spezifisch und wurden im Unterricht nicht behandelt
fig_hour = go.Figure()

# Fügt einen Scatter-Trace (Linie mit Füllung) zur Figur hinzu
fig_hour.add_trace(go.Scatter(
    x=hour_labels,                                           # X-Achse: Stunden-Labels (Liste von Strings)
    y=df_hour["delay_pct"],                                  # Y-Achse: Verspätungsrate in % (Spalte des DataFrames)
    mode="lines",                                            # Nur Linie, keine Punkte
    line=dict(color=COLOR_LINE, width=2.5, shape="spline"),  # Glatte blaue Linie, Breite 2.5
    fill="tozeroy",                                          # Fläche zwischen Linie und X-Achse füllen
    fillcolor="rgba(59,130,246,0.12)",                       # Sehr transparentes Blau als Füllung (rgba)
    name="Delay rate",                                       # Bezeichnung in der Legende
))

# Konfiguriert das Layout (Grösse, Farben, Achsen) des Liniendiagramms
fig_hour.update_layout(
    height=320,                                  # Höhe des Diagramms in Pixeln
    margin=dict(l=0, r=0, t=10, b=0),           # Innenabstände (links, rechts, oben, unten)
    plot_bgcolor="#ffffff",                      # Weisser Hintergrund im Diagramm
    paper_bgcolor="#ffffff",                     # Weisser Hintergrund ausserhalb
    xaxis=dict(
        title="Departure Hour",                  # Achsenbeschriftung X-Achse
        tickangle=0,                             # Tickbeschriftungen nicht rotieren
        gridcolor=COLOR_GRID,                    # Farbe des Gitternetzes
        showline=True,                           # Achsenlinie anzeigen
        linecolor="#e5e7eb",                     # Farbe der Achsenlinie (helles Grau)
        # Nur jede zweite Stunde beschriften damit es nicht zu voll wird
        # [::2] = Slicing: jeden zweiten Wert aus der Liste nehmen (Unterrichtsinhalt: Sequence Slicing)
        tickvals=hour_labels[::2],               # Positionen der Tick-Beschriftungen (jede 2. Stunde)
        ticktext=hour_labels[::2],               # Texte der Tick-Beschriftungen (jede 2. Stunde)
    ),
    yaxis=dict(
        title="% Flights Delayed",               # Achsenbeschriftung Y-Achse
        gridcolor=COLOR_GRID,                    # Farbe des Gitternetzes
        ticksuffix="%",                          # Prozentzeichen hinter jedem Tick-Wert
        range=[0, 45],                           # Y-Achse von 0 bis 45%
    ),
    showlegend=False,                            # Legende ausblenden
)

# Rendert das Liniendiagramm in der Streamlit-App (use_container_width=True = volle Breite)
st.plotly_chart(fig_hour, use_container_width=True)

# Horizontale Trennlinie zwischen den Charts
st.markdown("---")

# ── CHART 2: VERSPÄTUNGEN NACH WOCHENTAG (Balkendiagramm) ─────────────────────
# Zeigt eine Unterüberschrift für Chart 2
st.subheader("Delays by Day of Week")
# Zeigt einen erklärenden Hinweistext an
st.caption("Friday usually is the day with the biggest cumulated delay.")

# List Comprehension mit if/else: Freitag ("Fri") bekommt Rot (#EF4444),
# alle anderen Wochentage bekommen Lila (COLOR_BAR) (Unterrichtsinhalt: List Comprehension, bedingte Zuweisung)
bar_colors_weekday = [
    "#EF4444" if day == "Fri" else COLOR_BAR
    for day in df_weekday["day"]
]

# Erstellt ein leeres Plotly-Figur-Objekt für Chart 2
fig_weekday = go.Figure()

# Fügt einen Bar-Trace (Balkendiagramm) zur Figur hinzu
# Hilfsmittel: Claude – go.Bar ist Plotly-spezifisch und wurde im Unterricht nicht behandelt
fig_weekday.add_trace(go.Bar(
    x=df_weekday["day"],                                         # X-Achse: Wochentage (Spalte des DataFrames)
    y=df_weekday["delay_pct"],                                   # Y-Achse: Verspätungsrate in %
    marker_color=bar_colors_weekday,                             # Balkenfarben (Freitag rot, Rest lila)
    marker_line_width=0,                                         # Kein Rahmen um die Balken
    text=[f"{v}%" for v in df_weekday["delay_pct"]],             # List Comprehension: Prozentzahl als Beschriftung auf jedem Balken (Unterrichtsinhalt)
    textposition="outside",                                      # Beschriftung oberhalb des Balkens
    textfont=dict(size=12, color="#333333"),                     # Schriftgrösse 12, dunkelgrau
))

# Konfiguriert das Layout des Balkendiagramms
fig_weekday.update_layout(
    height=320,                                  # Höhe in Pixeln
    margin=dict(l=0, r=0, t=30, b=0),           # Innenabstände
    plot_bgcolor="#ffffff",                      # Weisser Diagramm-Hintergrund
    paper_bgcolor="#ffffff",                     # Weisser Paper-Hintergrund
    xaxis=dict(
        title="Day of Week",                     # Achsenbeschriftung X-Achse
        gridcolor=COLOR_GRID,                    # Gitternetzfarbe
        showline=True,                           # Achsenlinie anzeigen
        linecolor="#e5e7eb",                     # Farbe der Achsenlinie
    ),
    yaxis=dict(
        title="% Flights Delayed",               # Achsenbeschriftung Y-Achse
        gridcolor=COLOR_GRID,                    # Gitternetzfarbe
        ticksuffix="%",                          # Prozentzeichen hinter Tick-Werten
        range=[0, 30],                           # Y-Achse von 0 bis 30%
    ),
    showlegend=False,                            # Legende ausblenden
    bargap=0.35,                                 # Abstand zwischen den Balken (35% der Balkenbreite)
)

# Rendert das Balkendiagramm in der Streamlit-App
st.plotly_chart(fig_weekday, use_container_width=True)

# Horizontale Trennlinie
st.markdown("---")

# ── CHART 3: VERSPÄTUNGEN NACH AIRLINE (horizontales Balkendiagramm) ──────────
# Zeigt eine Unterüberschrift für Chart 3
st.subheader("Delays by Airline")
# Zeigt einen erklärenden Hinweistext an
st.caption("Sorted from most to least punctual - Hawaiian Airlines has the lowest delay rate of all airlines.")

# Definiert eine Hilfsfunktion, die basierend auf der Verspätungsrate eine Farbe zurückgibt
# Docstring erklärt die Funktion (Unterrichtsinhalt: def, return, if/elif/else)
def airline_color(pct: float) -> str:
    """Gibt eine Farbe abhängig von der Verspätungsrate zurück."""
    if pct < 16:   return "#10B981"   # Grün: unter 16% = sehr pünktlich
    elif pct < 22: return "#F59E0B"   # Gelb: 16–22% = durchschnittlich
    else:          return "#EF4444"   # Rot: über 22% = viele Verspätungen

# List Comprehension: ruft airline_color() für jeden Wert in der delay_pct-Spalte auf
# → erstellt eine Liste von Farbcodes (Unterrichtsinhalt: List Comprehension)
bar_colors_airline = [airline_color(p) for p in df_airline["delay_pct"]]

# Erstellt ein leeres Plotly-Figur-Objekt für Chart 3
fig_airline = go.Figure()

# Fügt einen horizontalen Bar-Trace zur Figur hinzu (orientation="h" = horizontal)
fig_airline.add_trace(go.Bar(
    x=df_airline["delay_pct"],                                   # X-Achse: Verspätungsrate in %
    y=df_airline["airline"],                                     # Y-Achse: Airline-Namen
    orientation="h",                                             # Horizontal ausrichten (h = horizontal)
    marker_color=bar_colors_airline,                             # Farbliste aus airline_color()
    marker_line_width=0,                                         # Kein Rahmen um die Balken
    text=[f"{v}%" for v in df_airline["delay_pct"]],             # List Comprehension: Prozent-Beschriftung rechts vom Balken (Unterrichtsinhalt)
    textposition="outside",                                      # Beschriftung ausserhalb des Balkens
    textfont=dict(size=11, color="#333333"),                     # Schriftgrösse 11, dunkelgrau
))

# Konfiguriert das Layout des horizontalen Balkendiagramms
fig_airline.update_layout(
    height=420,                                  # Höhe in Pixeln (grösser wegen vieler Airlines)
    margin=dict(l=0, r=60, t=10, b=0),          # Rechts 60px extra Platz für Beschriftungen
    plot_bgcolor="#ffffff",                      # Weisser Diagramm-Hintergrund
    paper_bgcolor="#ffffff",                     # Weisser Paper-Hintergrund
    xaxis=dict(
        title="% Flights Delayed",               # Achsenbeschriftung X-Achse
        gridcolor=COLOR_GRID,                    # Gitternetzfarbe
        ticksuffix="%",                          # Prozentzeichen hinter Tick-Werten
        range=[0, 34],                           # X-Achse von 0 bis 34%
    ),
    yaxis=dict(
        title="",                                # Kein Titel auf Y-Achse (Airline-Namen sprechen für sich)
        gridcolor=COLOR_GRID,                    # Gitternetzfarbe
        automargin=True,                         # Automatisch Platz für lange Airline-Namen reservieren
    ),
    showlegend=False,                            # Legende ausblenden
    bargap=0.25,                                 # Abstand zwischen den Balken (25% der Balkenbreite)
)

# Rendert das horizontale Balkendiagramm in der Streamlit-App
st.plotly_chart(fig_airline, use_container_width=True)

# ── Fussnote ──────────────────────────────────────────────────────────────────
# Horizontale Trennlinie vor der Fussnote
st.markdown("---")
# Zeigt die Datenquelle als kleinen Caption-Text an
st.caption("Source: Bureau of Transportation Statistics (BTS) · 2015 US Domestic Flights · Airports: ATL, ORD, JFK, LAX, DEN")
