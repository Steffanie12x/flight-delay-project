"""
utils/weather.py

Modul für stündliche Wetterdaten für 16 US-Flughäfen.
Ruft je nach Datum entweder historische Archivdaten, eine Wettervorhersage
oder einen historischen Tagesdurchschnitt der letzten 3 Jahre von der
Open-Meteo API ab. Falls alle API-Abrufe scheitern, wird ein einfacher
monatlicher Fallback-Wert verwendet.

Autoren: Ben Marbacher
Datum:   last week (Commit bd8715e)

Quellen:
- Claude (claude.ai): requests.get() mit params und timeout, raise_for_status(),
  pd.concat(), .mean().round(), target.replace(year=...) sowie die gesamte
  Logik der drei API-Abruf-Funktionen (_fetch_archive, _fetch_forecast,
  _get_historical_day_average) wurden mit Claude erarbeitet, da HTTP-Anfragen
  mit der requests-Library und die Open-Meteo-API nicht im Unterricht
  behandelt wurden.
"""

# Importiert requests für HTTP GET-Anfragen an die Open-Meteo API
# Hilfsmittel: Claude – requests wurde im Unterricht als Konzept eingeführt,
#    die konkrete Verwendung mit params, timeout und raise_for_status() jedoch nicht
import requests

# Importiert pandas für die Erstellung von DataFrames (Unterrichtsinhalt)
import pandas as pd

# Importiert date und datetime für Datumsberechnungen (Unterrichtsinhalt: datetime.strptime)
from datetime import date, datetime

# Dictionary: Flughafen-Code (Key) → Dictionary mit lat, lon und Name (Value)
# Verschachteltes Dictionary (Unterrichtsinhalt: Dictionary mit Dictionary als Value)
AIRPORT_COORDS = {
    "ATL": {"lat": 33.6407,  "lon": -84.4277,  "name": "Atlanta (ATL)"},
    "ORD": {"lat": 41.9742,  "lon": -87.9073,  "name": "Chicago O'Hare (ORD)"},
    "DFW": {"lat": 32.8998,  "lon": -97.0403,  "name": "Dallas Fort Worth (DFW)"},
    "DEN": {"lat": 39.8561,  "lon": -104.6737, "name": "Denver (DEN)"},
    "LAX": {"lat": 33.9425,  "lon": -118.4081, "name": "Los Angeles (LAX)"},
    "SFO": {"lat": 37.6213,  "lon": -122.3790, "name": "San Francisco (SFO)"},
    "PHX": {"lat": 33.4373,  "lon": -112.0078, "name": "Phoenix (PHX)"},
    "IAH": {"lat": 29.9902,  "lon": -95.3368,  "name": "Houston (IAH)"},
    "LAS": {"lat": 36.0840,  "lon": -115.1537, "name": "Las Vegas (LAS)"},
    "MSP": {"lat": 44.8848,  "lon": -93.2223,  "name": "Minneapolis (MSP)"},
    "MCO": {"lat": 28.4294,  "lon": -81.3089,  "name": "Orlando (MCO)"},
    "SEA": {"lat": 47.4502,  "lon": -122.3088, "name": "Seattle (SEA)"},
    "DTW": {"lat": 42.2162,  "lon": -83.3554,  "name": "Detroit (DTW)"},
    "BOS": {"lat": 42.3656,  "lon": -71.0096,  "name": "Boston (BOS)"},
    "EWR": {"lat": 40.6895,  "lon": -74.1745,  "name": "Newark (EWR)"},
    "JFK": {"lat": 40.6413,  "lon": -73.7781,  "name": "New York JFK (JFK)"},
}

# Maximale Anzahl Tage in der Zukunft, für die eine Wettervorhersage verfügbar ist (Integer)
MAX_FORECAST_DAYS = 16

# Liste der drei Vorjahre, die für den historischen Tagesdurchschnitt verwendet werden (Liste von Integers)
HISTORICAL_YEARS  = [2024, 2023, 2022]


# Definiert die öffentliche Hauptfunktion: gibt Wetterdaten für einen Flughafen und ein Datum zurück
# Typ-Annotationen (airport_code: str, flight_date: str) sind Unterrichtsinhalt
def get_weather(airport_code: str, flight_date: str) -> pd.DataFrame:
    # Prüft ob der Flughafen-Code im Dictionary vorhanden ist; wirft ValueError falls nicht
    if airport_code not in AIRPORT_COORDS:
        raise ValueError(f"Unbekannter Flughafen: {airport_code}")
    # Holt das coords-Dictionary für diesen Flughafen (Unterrichtsinhalt: Dictionary-Zugriff)
    coords     = AIRPORT_COORDS[airport_code]
    # Wandelt den Datumsstring "YYYY-MM-DD" in ein date-Objekt um (Unterrichtsinhalt: datetime.strptime)
    target     = datetime.strptime(flight_date, "%Y-%m-%d").date()
    # Holt das heutige Datum als date-Objekt
    today      = date.today()
    # Berechnet die Anzahl Tage zwischen heute und dem Zieldatum (Integer)
    days_ahead = (target - today).days

    # Verzweigung je nach Datum: Vergangenheit, nahe Zukunft oder weit in der Zukunft
    if target <= today:
        # Datum liegt in der Vergangenheit oder ist heute: Archivdaten abrufen
        return _fetch_archive(coords, flight_date)
    elif days_ahead <= MAX_FORECAST_DAYS:
        # Datum liegt innerhalb der nächsten 16 Tage: Vorhersage abrufen
        return _fetch_forecast(coords, flight_date)
    else:
        # Datum liegt mehr als 16 Tage in der Zukunft: historischen Tagesdurchschnitt berechnen
        return _get_historical_day_average(coords, target)


# Definiert eine private Hilfsfunktion zum Abrufen historischer Wetterdaten (Archiv-API)
# Hilfsmittel: Claude – requests.get() mit params-Dictionary und raise_for_status()
#    wurden im Unterricht nicht behandelt
def _fetch_archive(coords, flight_date):
    # URL der Open-Meteo Archiv-API (String)
    url = "https://archive-api.open-meteo.com/v1/archive"
    # Dictionary mit allen URL-Parametern für die API-Anfrage
    params = {
        "latitude":  coords["lat"],          # Breitengrad des Flughafens (float)
        "longitude": coords["lon"],          # Längengrad des Flughafens (float)
        "start_date": flight_date,           # Startdatum (String "YYYY-MM-DD")
        "end_date":   flight_date,           # Enddatum = gleicher Tag wie Startdatum
        "hourly": "temperature_2m,precipitation,snowfall,windspeed_10m,cloudcover",  # Angeforderte Variablen
        "timezone": "America/New_York",      # Zeitzone für die Stundenwerte
    }
    # Sendet HTTP GET-Anfrage an die API mit timeout=10 Sekunden
    # Hilfsmittel: Claude – requests.get() und timeout wurden im Unterricht nicht behandelt
    response = requests.get(url, params=params, timeout=10)
    # Wirft einen HTTP-Fehler falls der Statuscode nicht 2xx ist (z.B. 404, 500)
    # Hilfsmittel: Claude – raise_for_status() wurde im Unterricht nicht behandelt
    response.raise_for_status()
    # Wandelt die JSON-Antwort in ein Python-Dictionary um und gibt daraus einen DataFrame zurück
    return _parse_hourly(response.json())


# Definiert eine private Hilfsfunktion zum Abrufen von Wettervorhersagedaten
# Hilfsmittel: Claude – identische Struktur wie _fetch_archive, nur andere API-URL
def _fetch_forecast(coords, flight_date):
    # URL der Open-Meteo Forecast-API (String)
    url = "https://api.open-meteo.com/v1/forecast"
    # Dictionary mit allen URL-Parametern (identisch zu _fetch_archive)
    params = {
        "latitude":  coords["lat"],
        "longitude": coords["lon"],
        "start_date": flight_date,
        "end_date":   flight_date,
        "hourly": "temperature_2m,precipitation,snowfall,windspeed_10m,cloudcover",
        "timezone": "America/New_York",
    }
    # Sendet HTTP GET-Anfrage mit 10 Sekunden Timeout
    response = requests.get(url, params=params, timeout=10)
    # Fehler werfen falls HTTP-Statuscode kein Erfolg
    response.raise_for_status()
    # JSON-Antwort parsen und als DataFrame zurückgeben
    return _parse_hourly(response.json())


# Definiert eine private Hilfsfunktion zum Aufbau eines stündlichen DataFrames aus der API-Antwort
def _parse_hourly(data):
    # Erstellt einen pandas DataFrame mit 24 Zeilen (eine pro Stunde) aus dem API-JSON
    # range(24) erzeugt Stunden 0–23 (Unterrichtsinhalt: range())
    return pd.DataFrame({
        "hour":          range(24),                              # Stunden 0–23 als Integer
        "temperature":   data["hourly"]["temperature_2m"],       # Temperatur in °C pro Stunde (Liste)
        "precipitation": data["hourly"]["precipitation"],        # Niederschlag in mm pro Stunde (Liste)
        "snowfall":      data["hourly"]["snowfall"],             # Schneefall in mm pro Stunde (Liste)
        "windspeed":     data["hourly"]["windspeed_10m"],        # Windgeschwindigkeit in km/h (Liste)
        "cloudcover":    data["hourly"]["cloudcover"],           # Wolkenbedeckung in % (Liste)
    })


# Definiert eine private Hilfsfunktion, die den Durchschnitt desselben Tages
# über die letzten 3 Jahre berechnet falls keine Vorhersage verfügbar ist
# Hilfsmittel: Claude – pd.concat(), .mean(), .round() und target.replace(year=...)
#    wurden im Unterricht nicht behandelt
def _get_historical_day_average(coords, target):
    # Leere Liste für die DataFrames der einzelnen Jahre (Unterrichtsinhalt: leere Liste)
    all_days = []
    # For-Schleife über die drei historischen Jahre (Unterrichtsinhalt: for-Schleife)
    for year in HISTORICAL_YEARS:
        try:
            # Ersetzt das Jahr im Zieldatum durch das historische Jahr
            # Hilfsmittel: Claude – date.replace() wurde im Unterricht nicht behandelt
            historical_date = target.replace(year=year)
        except ValueError:
            # Sonderfall 29. Februar: Falls Jahr kein Schaltjahr, auf 28. Februar ausweichen
            historical_date = target.replace(year=year, day=28)
        try:
            # Ruft die Archivdaten für dieses historische Datum ab
            df = _fetch_archive(coords, historical_date.strftime("%Y-%m-%d"))
            # Hängt den DataFrame an die Liste an (Unterrichtsinhalt: .append())
            all_days.append(df)
        except Exception:
            # Falls der API-Abruf scheitert: dieses Jahr überspringen
            continue

    # Falls keine Daten gefunden wurden: Fallback-Funktion mit Monatsdurchschnitt aufrufen
    if not all_days:
        return _simple_fallback(target.month)

    # Verbindet alle DataFrames zu einem einzigen (stapelt Zeilen untereinander)
    # Hilfsmittel: Claude – pd.concat() wurde im Unterricht nicht behandelt
    combined  = pd.concat(all_days)
    # Berechnet den Spaltenmittelwert über alle Jahre und rundet auf 1 Nachkommastelle
    # Hilfsmittel: Claude – .mean().round() auf mehrere Spalten wurde im Unterricht nicht behandelt
    daily_avg = combined[["temperature", "precipitation", "snowfall", "windspeed", "cloudcover"]].mean().round(1)

    # Erstellt eine Liste von 24 Zeilen (eine pro Stunde) mit dem gleichen Tagesdurchschnitt
    rows = []
    for h in range(24):    # For-Schleife über Stunden 0–23 (Unterrichtsinhalt)
        rows.append({
            "hour":          h,
            "temperature":   daily_avg["temperature"],    # Gleicher Durchschnittswert für alle Stunden
            "precipitation": daily_avg["precipitation"],
            "snowfall":      daily_avg["snowfall"],
            "windspeed":     daily_avg["windspeed"],
            "cloudcover":    daily_avg["cloudcover"],
        })
    # Wandelt die Liste von Dictionaries in einen pandas DataFrame um (Unterrichtsinhalt: pd.DataFrame)
    return pd.DataFrame(rows)


# Definiert eine private Fallback-Funktion mit monatlichen Durchschnittswerten
# (wird verwendet wenn keine API-Daten verfügbar sind)
def _simple_fallback(month):
    # Dictionary: Monatsnummer (Integer) → Tupel (Tagesmax °C, Tagesmin °C, Niederschlag mm/h, Wind km/h)
    # Tupel und Dictionary sind Unterrichtsinhalt
    monthly = {
        1: (4,-4,0.12,25), 2: (6,-2,0.10,23), 3: (12,3,0.13,22),
        4: (17,7,0.12,20), 5: (22,12,0.13,18), 6: (27,17,0.11,16),
        7: (30,20,0.13,15), 8: (29,19,0.12,15), 9: (25,15,0.11,17),
        10: (18,8,0.10,19), 11: (11,2,0.11,22), 12: (5,-3,0.12,24),
    }
    # Holt die Monatswerte aus dem Dictionary (Standard: Aprildurchschnitt falls Monat fehlt)
    tmax, tmin, prcp_h, wind = monthly.get(month, (20,10,0.10,20))

    # Leere Liste für die 24 Stundenzeilen
    rows = []
    for h in range(24):    # For-Schleife über alle Stunden 0–23
        # Berechnet die Temperatur je nach Tageszeit (lineares Tagesgangsmodell)
        if 6 <= h <= 14:
            # Morgens bis Mittag: Temperatur steigt von tmin auf tmax
            temp = tmin + (tmax-tmin)*(h-6)/8
        elif 14 < h <= 20:
            # Nachmittags bis Abend: Temperatur fällt von tmax auf tmin
            temp = tmax - (tmax-tmin)*(h-14)/6
        else:
            # Nacht und früher Morgen: Temperatur bleibt auf tmin
            temp = tmin
        # Hängt eine Zeile mit allen Wetterwerten für diese Stunde an (Unterrichtsinhalt: .append())
        rows.append({
            "hour":          h,
            "temperature":   round(temp, 1),    # Temperatur auf 1 Nachkommastelle gerundet
            "precipitation": prcp_h,            # Stündlicher Niederschlag (float)
            "snowfall":      0.1 if month in [12, 1, 2] else 0.0,  # Schnee nur in Wintermonaten (Unterrichtsinhalt: Ternary)
            "windspeed":     float(wind),       # Windgeschwindigkeit als float
            "cloudcover":    50,                # Fixer Standardwert: 50% Wolkenbedeckung
        })
    return pd.DataFrame(rows)    # Gibt den fertigen DataFrame zurück


# Definiert eine Funktion zur Klassifizierung der Wetterbedingung als String
# Prüft Schwellenwerte der Wetterwerte in einer fixen Prioritätsreihenfolge (Unterrichtsinhalt: if/elif/else)
def classify_weather_condition(row):
    if row["snowfall"] is not None and row["snowfall"] > 0.5:             return "Heavy Snow"   # Starker Schneefall (>0.5mm)
    elif row["snowfall"] is not None and row["snowfall"] > 0:             return "Light Snow"   # Leichter Schneefall
    elif row["precipitation"] is not None and row["precipitation"] > 2.0: return "Heavy Rain"   # Starker Regen (>2mm)
    elif row["precipitation"] is not None and row["precipitation"] > 0.5: return "Light Rain"   # Leichter Regen
    elif row["windspeed"] is not None and row["windspeed"] > 50:          return "Strong Wind"  # Starker Wind (>50km/h)
    elif row["cloudcover"] is not None and row["cloudcover"] > 80:        return "Overcast"     # Stark bewölkt (>80%)
    else:                                                                  return "Good"         # Keine Beeinträchtigungen


# Definiert eine Funktion, die den ausgeschriebenen Namen eines Flughafens zurückgibt
def get_airport_name(airport_code):
    # Holt das innere Dictionary für den Code und daraus den "name"-Wert
    # Falls Code nicht gefunden: leeres Dict als Default, dann airport_code als Fallback (Unterrichtsinhalt: .get())
    return AIRPORT_COORDS.get(airport_code, {}).get("name", airport_code)


# Definiert eine Funktion, die alle Flughäfen als Dictionary zurückgibt (Name → Code)
def get_airport_list():
    # Dict Comprehension: kehrt das AIRPORT_COORDS-Dictionary um (Name als Key, Code als Value)
    # Unterrichtsinhalt: Dict Comprehension, .items()
    return {v["name"]: k for k, v in AIRPORT_COORDS.items()}
